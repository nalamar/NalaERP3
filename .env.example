# Allgemeine Einstellungen
APP_ENV=development

# API
API_ADDR=:8080
API_LOG_LEVEL=info

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nalaerp
POSTGRES_USER=nala
POSTGRES_PASSWORD=secret
# Vollständige DSN (überschreibt obige Werte, wenn gesetzt)
POSTGRES_DSN=postgres://nala:secret@postgres:5432/nalaerp?sslmode=disable

# MongoDB
MONGO_URI=mongodb://mongo:27017
MONGO_DB=nalaerp

# Redis
REDIS_ADDR=redis:6379
REDIS_DB=0
REDIS_PASSWORD=secret

# Assets/Conversion
# DPI für EMF→PNG Konvertierung (Inkscape/ImageMagick/LibreOffice-PDF-Pfad)
EMF_PNG_DPI=300
EMF_PNG_MIN_WIDTH=600
EMF_PNG_TARGET_WIDTH=1200
